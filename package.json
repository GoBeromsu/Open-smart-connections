{
  "name": "open-connections",
  "version": "3.9.9",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "description": "Link and chat with your notes using ChatGPT and embedding artificial intelligence from OpenAI.",
  "scripts": {
    "build": "node esbuild.js",
    "build:watch": "node esbuild.js --watch",
    "dev": "node scripts/dev.mjs",
    "dev:build": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:watch": "tsc --noEmit -p tsconfig.typecheck.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "ci": "pnpm run build && pnpm run lint && pnpm run test",
    "version": "node scripts/version.mjs",
    "postversion": "git push && git push --tags",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GoBeromsu/Open-smart-connections.git"
  },
  "keywords": [
    "Obsidian",
    "Smart",
    "Connections",
    "AI",
    "ChatGPT",
    "Embeddings",
    "Notes"
  ],
  "author": "Beomsu Koh",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/GoBeromsu/Open-smart-connections/issues"
  },
  "homepage": "https://github.com/GoBeromsu/Open-smart-connections",
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^8.57.1",
    "@huggingface/transformers": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/ui": "^1.0.0",
    "@xenova/transformers": "latest",
    "archiver": "^6.0.1",
    "axios": "^1.6.7",
    "dotenv": "^16.3.1",
    "esbuild": "^0.25.9",
    "eslint": "^8.0.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.0",
    "lint-staged": "^16.3.2",
    "swagger-jsdoc": "^6.2.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "base64-js": "^1.5.1",
    "better-sqlite3": "^12.8.0",
    "js-tiktoken": "^1.0.19",
    "lucide-static": "^0.414.0",
    "node-fetch": "^2.7.0",
    "obsidian": "latest"
  }
}
