{
  "name": "open-connections",
  "version": "3.9.36",
  "type": "module",
  "bin": {
    "open-connections-mcp": "dist/mcp.js"
  },
  "packageManager": "pnpm@10.28.2",
  "description": "Link and chat with your notes using ChatGPT and embedding artificial intelligence from OpenAI.",
  "scripts": {
    "build": "node esbuild.js",
    "build:watch": "node esbuild.js --watch",
    "dev": "node scripts/dev.mjs",
    "dev:build": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:watch": "tsc --noEmit -p tsconfig.typecheck.json --watch",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "verify:test-vault": "node scripts/verify-test-vault.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "ci": "pnpm run build && pnpm run lint && pnpm run test",
    "version": "node scripts/version.mjs",
    "postversion": "git push && git push --tags",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GoBeromsu/Open-smart-connections.git"
  },
  "keywords": [
    "Obsidian",
    "Smart",
    "Connections",
    "AI",
    "ChatGPT",
    "Embeddings",
    "Notes"
  ],
  "author": "Beomsu Koh",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/GoBeromsu/Open-smart-connections/issues"
  },
  "homepage": "https://github.com/GoBeromsu/Open-smart-connections",
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "9.30.1",
    "@huggingface/transformers": "^3.7.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.0.0",
    "@xenova/transformers": "latest",
    "archiver": "^6.0.1",
    "axios": "^1.6.7",
    "dotenv": "^16.3.1",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "14.0.0",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "jsdom": "^24.1.0",
    "lint-staged": "^16.3.2",
    "swagger-jsdoc": "^6.2.8",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "base64-js": "^1.5.1",
    "js-tiktoken": "^1.0.19",
    "lucide-static": "^0.414.0",
    "node-fetch": "^2.7.0",
    "obsidian": "latest"
  }
}
